<Window x:Class="SzepsegedenWPF.Felvetel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SzepsegedenWPF"
        mc:Ignorable="d"
        Title="Szépség Éden - Alkalmazott hozzáadása" Height="450" Width="900" WindowStartupLocation="CenterScreen">
    <Grid>
        <TextBox x:Name="Email" HorizontalAlignment="Left" Height="23" Margin="119,92,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="160"/>
        <TextBox x:Name="Password" HorizontalAlignment="Left" Height="23" Margin="119,136,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="160"/>
        <TextBox x:Name="Password_again" HorizontalAlignment="Left" Height="23" Margin="119,180,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="160"/>
        <TextBox x:Name="Surname" HorizontalAlignment="Left" Height="23" Margin="119,224,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="160"/>
        <TextBox x:Name="Firstname" HorizontalAlignment="Left" Height="23" Margin="119,268,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="160"/>
        <TextBox x:Name="Phone" HorizontalAlignment="Left" Height="23" Margin="119,312,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="160"/>
        <CheckBox x:Name="Service1" Content="Hajfestés" HorizontalAlignment="Left" Margin="352,92,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <CheckBox x:Name="Service2" Content="Hajvágás" HorizontalAlignment="Left" Margin="352,124,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <CheckBox x:Name="Service3" Content="Manikűr" HorizontalAlignment="Left" Margin="352,156,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <CheckBox x:Name="Service4" Content="Körömfestés" HorizontalAlignment="Left" Margin="352,188,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <CheckBox x:Name="Service5" Content="Pedikűr" HorizontalAlignment="Left" Margin="352,220,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <CheckBox x:Name="Service6" Content="Masszázs" HorizontalAlignment="Left" Margin="352,252,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.656,-2.096" FontWeight="Bold"/>
        <CheckBox x:Name="Service7" Content="Arckezelés" HorizontalAlignment="Left" Margin="352,284,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <CheckBox x:Name="Service8" Content="Gyantázás" HorizontalAlignment="Left" Margin="352,316,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <TextBox x:Name="MondayStart" HorizontalAlignment="Left" Height="23" Margin="584,115,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="MondayEnd" HorizontalAlignment="Left" Height="23" Margin="730,115,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="TuesdayStart" HorizontalAlignment="Left" Height="23" Margin="584,166,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="TuesdayEnd" HorizontalAlignment="Left" Height="23" Margin="730,166,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="WednesdayStart" HorizontalAlignment="Left" Height="23" Margin="584,217,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="WednesdayEnd" HorizontalAlignment="Left" Height="23" Margin="730,217,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="ThursdayStart" HorizontalAlignment="Left" Height="23" Margin="584,268,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="ThursdayEnd" HorizontalAlignment="Left" Height="23" Margin="730,268,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="FridayStart" HorizontalAlignment="Left" Height="23" Margin="584,319,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="FridayEnd" HorizontalAlignment="Left" Height="23" Margin="730,319,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Label x:Name="label" Content="Személyes adatok" HorizontalAlignment="Left" Margin="84,31,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="16"/>
        <Label x:Name="label1" Content="Email:" HorizontalAlignment="Left" Margin="35,88,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label x:Name="label2" Content="Jelszó:" HorizontalAlignment="Left" Margin="35,134,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label x:Name="label3" Content="Jelszó újra:" HorizontalAlignment="Left" Margin="20,179,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label x:Name="label4" Content="Vezetéknév:" HorizontalAlignment="Left" Margin="20,222,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label x:Name="label5" Content="Keresztnév:" HorizontalAlignment="Left" Margin="20,266,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label x:Name="label6" Content="Telefonszám:" HorizontalAlignment="Left" Margin="20,310,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label x:Name="label7" Content="Munkakör" HorizontalAlignment="Left" Margin="344,31,0,0" VerticalAlignment="Top" FontSize="16" FontWeight="Bold"/>
        <Label x:Name="label8" Content="Munkaidő" HorizontalAlignment="Left" Margin="600,31,0,0" VerticalAlignment="Top" FontSize="16" FontWeight="Bold"/>
        <Label x:Name="label9" Content="Hétfő:" HorizontalAlignment="Left" Margin="495,112,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label x:Name="label10" Content="Kedd:" HorizontalAlignment="Left" Margin="495,163,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label x:Name="label11" Content="Szerda:" HorizontalAlignment="Left" Margin="495,214,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label x:Name="label12" Content="Csütörtök:" HorizontalAlignment="Left" Margin="495,265,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label x:Name="label13" Content="Péntek:" HorizontalAlignment="Left" Margin="495,316,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label x:Name="label14" Content="Kezdés" HorizontalAlignment="Left" Margin="619,82,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label x:Name="label15" Content="Befejezés" HorizontalAlignment="Left" Margin="756,82,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Button x:Name="button" Content="Létrehoz" HorizontalAlignment="Center" Margin="678,370,0,0" VerticalAlignment="Top" Width="100" Height="30" Click="Create" FontSize="16" FontWeight="Bold"/>
        <Button x:Name="button1" Content="Vissza a Menübe" HorizontalAlignment="Left" Height="30" Margin="84,370,0,0" VerticalAlignment="Top" Width="175" FontWeight="Bold" FontSize="16" Click="Menu"/>
    </Grid>
</Window>
